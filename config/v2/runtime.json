{
  "schema_version": 2,
  "config_version": "runtime_v3_freeze_overlay_2026_07_17",
  "runtime_dir": ".runtime/v2",
  "strategy_config": "strategy.json",
  "long_watchlist": "long_watchlist.json",
  "server": {
    "host": "127.0.0.1",
    "port": 5000,
    "debug": false,
    "use_reloader": false,
    "allow_insecure_non_loopback": false
  },
  "pipeline": {
    "event_queue_size": 512,
    "priority_queue_size": 64,
    "market_workers": 6,
    "normalization_workers": 2,
    "strategy_workers": 3,
    "deepseek_workers": 4,
    "shutdown_timeout_seconds": 15,
    "full_market_refresh_seconds": 30,
    "candidate_refresh_seconds": 5,
    "publish_heartbeat_seconds": 15
  },
  "market_data": {
    "eastmoney_timeout_seconds": 20,
    "candidate_timeout_seconds": 3,
    "history_timeout_seconds": 12,
    "research_timeout_seconds": 8,
    "minimum_market_rows": 1000,
    "candidate_pool_size": 120,
    "single_flight": true,
    "circuit_breaker_failures": 3,
    "circuit_breaker_seconds": 60
  },
  "deepseek": {
    "enabled": true,
    "base_url": "https://api.deepseek.com/v1",
    "model": "deepseek-chat",
    "timeout_seconds": 12,
    "batch_size": 8,
    "max_tokens": 1800,
    "confidence_coverage_min": 0.5,
    "daily_hard_limit": 188,
    "strategy_limits": {
      "today": 70,
      "tomorrow": 45,
      "d25": 35,
      "long": 18,
      "shared_preheat": 15,
      "emergency": 5
    }
  },
  "api": {
    "default_top_n": 10,
    "maximum_top_n": 18,
    "event_page_limit": 100,
    "maximum_event_page_limit": 500,
    "sse_history_size": 256,
    "sse_client_queue_size": 16,
    "sse_max_clients": 32
  }
}
